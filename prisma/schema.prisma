generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Message {
  id                String   @id @default(uuid())
  title             String
  theme             String?
  caption           String?
  description       String?
  serviceTag        String?
  youtubeLink       String?
  preacher          String?
  preacherThumbnail String?
  messageThumbnail  String?
  pdfFile           String?
  audioFile         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
